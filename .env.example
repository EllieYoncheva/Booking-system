# Public Keycloak settings (Vite injects only VITE_*)
# In Keycloak client: Valid redirect URIs = http://localhost:3001/* (same port as PORT in server/.env)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=booking-system
VITE_KEYCLOAK_CLIENT_ID=booking-system-web

# Leave unset in dev/prod single-port setup (same-origin /api)
# VITE_API_URL=
