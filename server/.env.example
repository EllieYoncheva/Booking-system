# Server — single public port for React + /api (Keycloak stays on its own port, e.g. 8080)
PORT=3001
NODE_ENV=development

# MySQL (use with mysql2/pg when you add persistence)
DATABASE_URL=mysql://root:password@localhost:3306/booking_system

# Keycloak — JWT validation (resource server; replaces Spring OAuth2 resource server)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=booking-system
KEYCLOAK_ISSUER=http://localhost:8080/realms/booking-system
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/booking-system/protocol/openid-connect/certs

# Keycloak Admin API (server-side only; for user/role management — never expose secret to React)
KEYCLOAK_ADMIN_CLIENT_ID=booking-api
KEYCLOAK_ADMIN_CLIENT_SECRET=
